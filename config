[
  {
    // Bar dimensions
    "height": 30,
    "spacing": 5,
    "margin": 0,

    // Where to show the bar
    //"output": ["eDP-1", "DP-7"],
    "output": ["eDP-1"],

    // Choose the order of the modules
    "modules-left": ["custom/spacer", "clock", "custom/banner"],
    "modules-center": ["sway/workspaces"],
    "modules-right": ["pulseaudio", "network", "battery", "custom/spacer"],

    // Modules configuration
    "sway/workspaces": {
      "disable-scroll": true,
      "all-outputs": true,
      "persistent-workspaces": {
        "1": [],
        "2": [],
        "3": [],
        "4": [],
        "5": [],
        "6": [],
        "7": [],
        "8": [],
        "9": []
      },
      "format": "{icon}",
      "format-icons": {
        "1": "ΎΤ╡",
        "2": "ΎΕκ",
        "3": "≤░Ζσ",
        "4": "ΎΚσ",
        "5": "ΎΗ╝",
        "6": "ΎΔι",
        "7": "ΎΒ╡",
        "8": "ΎΚΚ",
        "9": "ΎΓχ",
        "urgent": "ΎΒς",
        "default": "ΎΕΣ"
      }
    },
    "clock": {
      "interval": 1,
      "tooltip-format": "{calendar}",
      "format-alt": "<b>{:%a %d %B %Y}</b>",
      "format": "<b>{:%T}\t</b>"
    },
    "network": {
      "format-wifi": "ΎΘτ",
      "tooltip-format-wifi": "connected to {essid} ({signalStrength}%) with {ifname} via {gwaddr} ΎΘτ",
      "format-ethernet": "≤░ΙΑ",
      "tooltip-format-ethernet": "connected as {ipaddr}/{cidr} with {ifname} via {gwaddr} ≤░ΙΑ",
      "format-linked": "≤░ΙΑ",
      "tooltip-format-linked": "connected (No IP) with {ifname} via {gwaddr} ≤░ΙΑ",
      "format-disconnected": "≤░ΙΓ",
      "tooltip-format-disconnected": "disconnected",
      "on-click": "kitty --class scratch nmtui-connect"
    },
    "battery": {
      "states": {
        "good": 95,
        "warning": 30,
        "critical": 15
      },
      "format": "{icon}",
      "tooltip-format": "{capacity}% (remaining time: {time})",
      "format-charging": "ΎΔπ",
      "tooltip-format-charging": "{capacity}% (time to full charge: {time})",
      "format-not-charging": "ΎΘο",
      "tooltip-format-not-charging": "{capacity}% (not charging)",
      "format-plugged": "ΎΘο",
      "tooltip-format-plugged": "{capacity}% (charge)",
      "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "tray": {
      "spacing": 10
    },
    "pulseaudio": {
      "format": "<b>{volume}% {icon}  {format_source}</b>",
      "format-bluetooth": "<b>{volume}% {icon}ΎΛΦ {format_source}</b>",
      "format-bluetooth-muted": "<b>ΎΣο  {icon}ΎΛΦ {format_source}</b>",
      "format-muted": "<b>ΎΣο  {format_source}</b>",
      "format-source": "<b>{volume}% ΎΕ░</b>",
      "format-source-muted": "ΎΕ▒",
      "format-icons": {
        "headphone": "≤░ΜΜ",
        "hands-free": "≤░ΜΜ",
        "headset": "≤░ΜΟ",
        "phone": "ΎΓΧ",
        "portable": "ΎΕΜ",
        "car": "ΎΗ╣",
        "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
      },
      "on-click": "kitty --class scratch pulsemixer"
    },
    "custom/banner": {
      "exec": "~/.config/waybar/bin/banner.py",
      "format": "<b>{0}</b>",
      "interval": 3600,
      "tooltip": false
    },
    "custom/spacer": {
      "format": " ",
      "tooltip": false
    }
  },
  {
    // Bar dimensions and position
    "position": "bottom",
    "height": 30,
    "spacing": 5,
    "margin": 0,

    // Where to show the bar
    //"output": ["eDP-1", "DP-7"],
    "output": ["eDP-1"],

    // Choose the order of the modules
    "modules-left": ["custom/spacer", "tray", "sway/mode", "custom/media"],
    "modules-center": ["idle_inhibitor"],
    "modules-right": ["cpu", "memory", "temperature", "backlight", "custom/spacer"],
    "sway/mode": {
      "format": "<span style=\"italic\">{}</span>"
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "ΎΒχ",
        "deactivated": "ΎΒ░"
      }
    },
    "cpu": {
      "format": "<b>{usage}% CPU</b>",
      "tooltip": false
    },
    "memory": {
      "format": "<b>{}% MEM</b>"
    },
    "temperature": {
      "critical-threshold": 80,
      "format": "<b>{temperatureC}┬░C {icon}</b>",
      "format-icons": ["ΎΜΜ", "ΎΜΛ", "ΎΜΚ", "ΎΜΙ", "ΎΜΘ"]
    },
    "backlight": {
      "format": "<b>{percent}% {icon}</b>",
      "format-icons": ["≤░δσ", "≤▒σΟ", "≤▒σΠ", "≤▒σΡ", "≤▒σΣ", "≤▒σΤ", "≤▒σΥ", "≤▒σΦ", "≤▒σΧ", "≤▒σΨ", "≤░δρ"]
    },
    "custom/media": {
      "format": "<b>{icon} {0}</b>",
      "return-type": "json",
      "max-length": 40,
      "format-icons": {
          "spotify": "ΎΗ╝ ",
          "default": "ΎΒΜ "
      },
      "escape": true,
      "exec": "~/.config/waybar/bin/mediaplayer.py"
    },
    "custom/spacer": {
      "format": " ",
      "tooltip": false
    }
  }
]
