[
  {
    // Bar dimensions
    "height": 30,
    "spacing": 4,
    "margin-top": 10,
    "margin-left": 10,
    "margin-right": 10,
    "margin-bottom": 0,

    // Where to show the bar
    "output": ["eDP-1", "DP-7"],
    //"output": ["eDP-1"],

    // Choose the order of the modules
    "modules-left": ["clock", "custom/banner"],
    "modules-center": ["sway/workspaces"],
    "modules-right": ["pulseaudio", "network", "battery"],

    // Modules configuration
    "sway/workspaces": {
      "disable-scroll": true,
      "all-outputs": true,
      "persistent-workspaces": {
        "1": [],
        "2": [],
        "3": [],
        "4": [],
        "5": [],
        "6": [],
        "7": [],
        "8": [],
        "9": []
      },
      "format": "{icon}",
      "format-icons": {
        "1": "яТ╡",
        "2": "яДб",
        "3": "ґ░Ей",
        "4": "яЙй",
        "5": "яЖ╝",
        "6": "яГа",
        "7": "яБ╡",
        "8": "яЙЙ",
        "9": "яВо",
        "urgent": "яБк",
        "default": "яДС"
      }
    },
    "clock": {
      "interval": 1,
      "tooltip-format": "{calendar}",
      "format-alt": "{:%a %d %B %Y}",
      "format": "{:%T}"
    },
    "network": {
      "format-wifi": "яЗл",
      "tooltip-format-wifi": "connected to {essid} ({signalStrength}%) with {ifname} via {gwaddr} яЗл",
      "format-ethernet": "ґ░ИА",
      "tooltip-format-ethernet": "connected as {ipaddr}/{cidr} with {ifname} via {gwaddr} ґ░ИА",
      "format-linked": "ґ░ИА",
      "tooltip-format-linked": "connected (No IP) with {ifname} via {gwaddr} ґ░ИА",
      "format-disconnected": "ґ░ИВ",
      "tooltip-format-disconnected": "disconnected",
      "on-click": "kitty --class scratch nmtui-connect"
    },
    "battery": {
      "states": {
        "good": 95,
        "warning": 30,
        "critical": 15
      },
      "format": "{icon}",
      "tooltip-format": "{capacity}% (remaining time: {time})",
      "format-charging": "яГз",
      "tooltip-format-charging": "{capacity}% (time to full charge: {time})",
      "format-not-charging": "яЗж",
      "tooltip-format-not-charging": "{capacity}% (not charging)",
      "format-plugged": "яЗж",
      "tooltip-format-plugged": "{capacity}% (charge)",
      "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "tray": {
      "spacing": 10
    },
    "pulseaudio": {
      "format": "{volume}% {icon}  {format_source}",
      "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
      "format-bluetooth-muted": "яСж  {icon}яКФ {format_source}",
      "format-muted": "яСж  {format_source}",
      "format-source": "{volume}% яД░",
      "format-source-muted": "яД▒",
      "format-icons": {
        "headphone": "ґ░ЛЛ",
        "hands-free": "ґ░ЛЛ",
        "headset": "ґ░ЛО",
        "phone": "яВХ",
        "portable": "яДЛ",
        "car": "яЖ╣",
        "default": ["яАж", "яАз", "яАи"]
      },
      "on-click": "kitty --class scratch pulsemixer"
    },
    "custom/banner": {
      "exec": "~/.config/waybar/bin/banner.py",
      "format": "<b>{0}</b>",
      "interval": 3600,
      "tooltip": false
    },
  },
  {
    // Bar dimensions and position
    "position": "bottom",
    "height": 30,
    "spacing": 4,
    "margin-top": 0,
    "margin-left": 10,
    "margin-right": 10,
    "margin-bottom": 10,

    // Where to show the bar
    "output": ["eDP-1", "DP-7"],
    //"output": ["eDP-1"],

    // Choose the order of the modules
    "modules-left": ["tray", "sway/mode", "custom/media"],
    "modules-center": ["idle_inhibitor"],
    "modules-right": ["cpu", "memory", "temperature", "backlight"],
    "sway/mode": {
      "format": "<span style=\"italic\">{}</span>"
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "яБо",
        "deactivated": "яБ░"
      }
    },
    "cpu": {
      "format": "{usage}% CPU",
      "tooltip": false
    },
    "memory": {
      "format": "{}% MEM"
    },
    "temperature": {
      "critical-threshold": 80,
      "format": "{temperatureC}┬░C {icon}",
      "format-icons": ["яЛЛ", "яЛК", "яЛЙ", "яЛИ", "яЛЗ"]
    },
    "backlight": {
      "format": "{percent}% {icon}",
      "format-icons": ["ґ░Ый", "ґ▒йО", "ґ▒йП", "ґ▒йР", "ґ▒йС", "ґ▒йТ", "ґ▒йУ", "ґ▒йФ", "ґ▒йХ", "ґ▒йЦ", "ґ░Ыи"]
    },
    "custom/media": {
      "format": "{icon} {0}",
      "return-type": "json",
      "max-length": 40,
      "format-icons": {
          "spotify": "яЖ╝ ",
          "default": "яБЛ "
      },
      "escape": true,
      "exec": "~/.config/waybar/bin/mediaplayer.py"
    },
  }
]
